# WebSocket endpoint для получения объектов
# Пример: ws://localhost:8080/ws
# VITE_WS_URL=ws://31.42.189.153:8080/ws
VITE_WS_URL=ws://localhost:8080/ws
# SIM_COUNT=10

# ---- Опційно (Node WS server) ----
# PORT=8080
# WS_PATH=/ws
# API_KEY=demo-key
API_KEYS=demo-key-2, demo-key-3

# ---- Опційно (Frontend) ----
# Список ключів (для підказки на екрані логіну). Має бути з префіксом VITE_, бо це фронт.
VITE_API_KEYS=demo-key-2, demo-key-3

# Швидкість «остаточної втрати» об’єктів на сервері:
# скільки об’єктів в середньому зникає за секунду (сумарно по всіх об’єктах).
# TARGET_DEAD_PER_SEC=0.3

# ---- Опційно (Frontend) ----
# Для продакшена/окремого API сервера: базовий URL для reset endpoint.
# Якщо задано, фронт робить POST ${VITE_RESET_URL_BASE}/reset
# VITE_RESET_URL_BASE=https://your-api.example.com